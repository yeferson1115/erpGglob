<Window
    x:Class="Gglob.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Gglob ERP"
    Width="900"
    Height="560"
    Background="#f8f9fa"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0d6efd" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0b5ed7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputText" TargetType="TextBox">
            <Setter Property="Margin" Value="0,6,0,12" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="InputPassword" TargetType="PasswordBox">
            <Setter Property="Margin" Value="0,6,0,12" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Padding="20" Background="#0d6efd" CornerRadius="14" Margin="0,0,16,0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Gglob ERP" Foreground="White" FontWeight="Bold" FontSize="32" />
                <TextBlock Margin="0,14,0,0" TextWrapping="Wrap" Foreground="#e7f1ff" FontSize="15"
                           Text="Inicia sesión para obtener permisos, rol de negocio y acceso según perfil (dueño o cajero)." />
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Padding="28" Background="White" CornerRadius="14" BorderBrush="#dee2e6" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Ingreso al sistema" FontSize="26" FontWeight="SemiBold" Foreground="#212529" />

                <StackPanel Grid.Row="1" Margin="0,18,0,0">
                    <TextBlock Text="URL API app_web" FontWeight="SemiBold" />
                    <TextBox x:Name="ApiBaseUrlTextBox" Style="{StaticResource InputText}" Text="http://localhost:8000/api" />

                    <TextBlock Text="Correo" FontWeight="SemiBold" />
                    <TextBox x:Name="EmailTextBox" Style="{StaticResource InputText}" />

                    <TextBlock Text="Contraseña" FontWeight="SemiBold" />
                    <PasswordBox x:Name="PasswordBox" Style="{StaticResource InputPassword}" />

                    <Button x:Name="LoginButton" Style="{StaticResource PrimaryButton}" Click="LoginButton_Click" Content="Iniciar sesión" Width="180" />

                    <TextBlock x:Name="StatusTextBlock" Margin="0,12,0,4" Foreground="#495057" TextWrapping="Wrap" />

                    <Border x:Name="SessionPanel" Visibility="Collapsed" Background="#f1f3f5" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="Sesión iniciada" FontSize="16" FontWeight="Bold" Foreground="#212529" />
                            <TextBlock x:Name="UserNameTextBlock" Margin="0,8,0,0" />
                            <TextBlock x:Name="BusinessTextBlock" Margin="0,2,0,0" />
                            <TextBlock x:Name="BusinessRoleTextBlock" Margin="0,2,0,0" />
                            <TextBlock x:Name="RolesTextBlock" Margin="0,2,0,0" TextWrapping="Wrap" />
                            <TextBlock x:Name="PermissionsTextBlock" Margin="0,2,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <TextBlock Margin="0,14,0,0" FontSize="14">
                        <Run Text="¿No tienes cuenta? " />
                        <Hyperlink Click="Hyperlink_Click" Foreground="#0d6efd">
                            <Run Text="Regístrate aquí" />
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
