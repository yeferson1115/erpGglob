<Window
    x:Class="Gglob.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:Gglob.Views"
    Title="Gglob ERP Desk"
    Width="1180"
    Height="760"
    Background="#f4f6fb"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Resources>
        <SolidColorBrush x:Key="BrandBrush" Color="#2563eb" />
        <SolidColorBrush x:Key="BrandBrushHover" Color="#1d4ed8" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#ffffff" />
        <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#f8fafc" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#dbe3f0" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1f2937" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BrandBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome" Background="{TemplateBinding Background}" CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.2" Color="#1e3a8a" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource BrandBrushHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#f3f6fc" />
            <Setter Property="Foreground" Value="#1f2937" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SecondaryButtonChrome" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SecondaryButtonChrome" Property="Background" Value="#e8eefb" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="PrimaryButtonSpacious" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Padding" Value="18,12" />
        </Style>

        <Style x:Key="InputText" TargetType="TextBox">
            <Setter Property="Margin" Value="0,6,0,12" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="InputPassword" TargetType="PasswordBox">
            <Setter Property="Margin" Value="0,6,0,12" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,6,0,12" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="0,6,0,12" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="RowBackground" Value="White" />
            <Setter Property="AlternatingRowBackground" Value="#f8fafc" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#eef2ff" />
                        <Setter Property="Foreground" Value="#334155" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Padding" Value="8,6" />
                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,6" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="#e2e8f0" />
        </Style>

        <Style TargetType="Thumb">
            <Setter Property="Background" Value="#94a3b8" />
            <Setter Property="BorderBrush" Value="#94a3b8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#64748b" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <views:LoginView x:Name="LoginViewControl" LoginRequested="LoginViewControl_LoginRequested" RegisterRequested="LoginViewControl_RegisterRequested" />

        <Grid x:Name="DashboardRoot" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,14,0" CornerRadius="14" Background="#264f9c" Padding="14">
                <DockPanel>
                    <Button DockPanel.Dock="Bottom" Style="{StaticResource PrimaryButton}" Content="🚪 Cerrar sesión" Padding="18,12" Click="LogoutButton_Click" />
                    <StackPanel>
                        <TextBlock Text="GglobERP Desk" Foreground="White" FontSize="22" FontWeight="Bold" />
                        <TextBlock x:Name="DashboardUserTextBlock" Margin="0,4,0,2" Foreground="#dce8ff" />
                        <TextBlock x:Name="DashboardBusinessTextBlock" Margin="0,0,0,12" Foreground="#dce8ff" TextWrapping="Wrap" />

                        <Border Background="#406fc8" CornerRadius="10" Padding="10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Rol en negocio" Foreground="#dce8ff" FontSize="12" />
                                <TextBlock x:Name="DashboardRoleTextBlock" Foreground="White" FontSize="15" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Servicios" Foreground="#dce8ff" FontSize="12" FontWeight="Bold" Margin="0,0,0,8" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="430">
                            <StackPanel x:Name="ServicesMenuPanel" />
                        </ScrollViewer>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Background="White" CornerRadius="12" Padding="14" BorderBrush="#e2e8f3" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="📊 Dashboard" FontSize="25" FontWeight="SemiBold" Foreground="#1f2937" />
                        <TextBlock Text="Vista principal por permisos y servicios activos." Foreground="#6b7280" Margin="0,3,0,10" />
                        <WrapPanel>
                            <Border Background="#e8f0ff" CornerRadius="8" Padding="8,5" Margin="0,0,8,8">
                                <TextBlock x:Name="PlanBadgeText" Foreground="#234ea0" FontWeight="SemiBold" />
                            </Border>
                            <Border Background="#ecfeff" CornerRadius="8" Padding="8,5" Margin="0,0,8,8">
                                <TextBlock x:Name="StatusBadgeText" Foreground="#0a7f8c" FontWeight="SemiBold" />
                            </Border>
                            <Border Background="#eafcf3" CornerRadius="8" Padding="8,5" Margin="0,0,8,8">
                                <TextBlock x:Name="ActiveServicesBadgeText" Foreground="#15803d" FontWeight="SemiBold" />
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border x:Name="AvailableModulesPanel" Grid.Row="1" Margin="0,12,0,0" Background="White" CornerRadius="12" Padding="14" BorderBrush="#e2e8f3" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="🧩 Módulos disponibles" FontSize="18" FontWeight="SemiBold" Foreground="#1f2937" Margin="0,0,0,10" />
                        <WrapPanel x:Name="ActiveServicesCardsPanel" />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Border x:Name="DefaultPanel" Background="White" CornerRadius="12" Padding="14" BorderBrush="#e2e8f3" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Resumen operativo" FontSize="18" FontWeight="SemiBold" Foreground="#1f2937" Margin="0,0,0,10" />
                            <TextBlock Text="Selecciona un servicio del menú lateral para abrir su módulo. Gglob Pay se mostrará al hacer clic en su opción." Foreground="#6b7280" TextWrapping="Wrap" Margin="0,0,0,12" />
                            <UniformGrid Columns="3" Rows="1">
                                <Border Margin="0,0,8,0" Padding="12" Background="#f8fbff" CornerRadius="8" BorderBrush="#d9e4ff" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Pagos del día" Foreground="#6b7280" />
                                        <TextBlock Text="$0" FontSize="20" FontWeight="Bold" Foreground="#234ea0" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,0,8,0" Padding="12" Background="#f8fbff" CornerRadius="8" BorderBrush="#d9e4ff" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Servicios activos" Foreground="#6b7280" />
                                        <TextBlock x:Name="SummaryServicesText" Text="0" FontSize="20" FontWeight="Bold" Foreground="#234ea0" />
                                    </StackPanel>
                                </Border>
                                <Border Padding="12" Background="#f8fbff" CornerRadius="8" BorderBrush="#d9e4ff" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Estado actual" Foreground="#6b7280" />
                                        <TextBlock Text="Listo" FontSize="20" FontWeight="Bold" Foreground="#15803d" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>



                    <Border x:Name="GglobPosPanel" Visibility="Collapsed" Background="White" CornerRadius="12" Padding="14" BorderBrush="#e2e8f3" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="🧾 Gglob POS" FontSize="20" FontWeight="SemiBold" Foreground="#1f2937" />
                            <TextBlock Text="Accesos rápidos del punto de venta. Aquí podrán convivir más botones de operación." Foreground="#6b7280" Margin="0,4,0,14" TextWrapping="Wrap" />
                            <WrapPanel>
                                <Button x:Name="OpenCategoriesButton" Content="🗂️ Categorías" Width="220" Height="56" Margin="0,0,12,12" Background="#f97316" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0" Click="OpenCategoriesButton_Click" />
                                <Button x:Name="OpenPosBlueprintButton" Content="🧠 POS completo (visual)" Width="220" Height="56" Margin="0,0,12,12" Background="#0f766e" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0" Click="OpenPosBlueprintButton_Click" />
                                <Button Content="🧺 Productos (próximamente)" Width="220" Height="56" Margin="0,0,12,12" IsEnabled="False" />
                                <Button Content="🧾 Pedidos (próximamente)" Width="220" Height="56" Margin="0,0,12,12" IsEnabled="False" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border x:Name="PosBlueprintPanel" Visibility="Collapsed" Background="White" CornerRadius="12" Padding="14" BorderBrush="#e2e8f3" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,12">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="🧠 Diseño visual POS (punto a punto)" FontSize="20" FontWeight="SemiBold" Foreground="#1f2937" />
                                    <TextBlock Text="Aquí defines y guardas en app_web toda la estructura visual y funcional solicitada." Foreground="#6b7280" Margin="0,3,0,0" />
                                </StackPanel>
                                <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Content="↩ Volver a POS" Margin="0,0,8,0" Click="BackToPosButton_Click" />
                                    <Button Content="📥 Cargar" Margin="0,0,8,0" Click="LoadPosBlueprintButton_Click" />
                                    <Button Content="💾 Guardar en app_web" Click="SavePosBlueprintButton_Click" />
                                </WrapPanel>
                            </DockPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Análisis punto a punto (resumen ejecutivo)" FontWeight="SemiBold" />
                                    <TextBox x:Name="PosAnalysisTextBox" Style="{StaticResource InputText}" Height="180" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />

                                    <TabControl>
                                        <TabItem Header="📊 Panel estadístico">
                                            <TextBox x:Name="PosStatsPanelTextBox" Margin="0,8,0,0" Height="190" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                                     Text="Filtros: sucursal/punto de venta, periodo (hoy/ayer/semana/mes/rango).&#x0a;Widgets: ventas por forma de pago + torta, ganancias, ventas por categoría, ventas por hora, producto, turno.&#x0a;Regla de acceso: solo plan pago con nube activa, vista inicial día actual y filtros dinámicos." />
                                        </TabItem>
                                        <TabItem Header="📦 Inventarios">
                                            <Grid Margin="0,8,0,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <Border Grid.Row="0" Background="#f8fbff" BorderBrush="#d9e4ff" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                                                    <TextBlock Text="Pestaña visual POS &gt; Inventarios (app_desk): creación/modificación de productos, control de existencias y KIT/COMBO."
                                                               Foreground="#334155"
                                                               TextWrapping="Wrap" />
                                                </Border>

                                                <TabControl Grid.Row="1">
                                                    <TabItem Header="Creación de producto">
                                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                            <StackPanel Margin="8">
                                                                <UniformGrid Columns="2" Margin="0,0,0,8">
                                                                    <StackPanel Margin="0,0,8,8">
                                                                        <TextBlock Text="Código del producto" FontWeight="SemiBold" />
                                                                        <TextBox x:Name="DeskProductCodeTextBox" Style="{StaticResource InputText}" />
                                                                    </StackPanel>
                                                                    <StackPanel Margin="0,0,0,8">
                                                                        <TextBlock Text="Nombre del producto" FontWeight="SemiBold" />
                                                                        <TextBox x:Name="DeskProductNameTextBox" Style="{StaticResource InputText}" />
                                                                    </StackPanel>
                                                                    <StackPanel Margin="0,0,8,8">
                                                                        <TextBlock Text="Categoría del producto" FontWeight="SemiBold" />
                                                                        <ComboBox x:Name="DeskProductCategoryComboBox" DisplayMemberPath="Name" SelectedValuePath="Id" Height="38" />
                                                                    </StackPanel>
                                                                    <StackPanel Margin="0,0,0,8">
                                                                        <TextBlock Text="Precio del producto" FontWeight="SemiBold" />
                                                                        <TextBox x:Name="DeskProductPriceTextBox" Style="{StaticResource InputText}" />
                                                                    </StackPanel>
                                                                </UniformGrid>

                                                                <CheckBox x:Name="DeskTracksInventoryCheck"
                                                                          Content="El producto tiene inventario de existencias"
                                                                          Margin="0,6,0,8"
                                                                          IsChecked="True"
                                                                          Checked="DeskTracksInventoryCheck_Changed"
                                                                          Unchecked="DeskTracksInventoryCheck_Changed" />

                                                                <Grid x:Name="DeskInventoryStockPanel" Margin="0,0,0,10">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel Margin="0,0,8,0">
                                                                        <TextBlock Text="Número de existencias en inventario" FontWeight="SemiBold" />
                                                                        <TextBox x:Name="DeskStockQuantityTextBox" Style="{StaticResource InputText}" />
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="1">
                                                                        <TextBlock Text="Existencias mínimas" FontWeight="SemiBold" />
                                                                        <TextBox x:Name="DeskMinimumStockTextBox" Style="{StaticResource InputText}" />
                                                                        <TextBlock Text="Al llegar al mínimo se deben solicitar nuevas existencias al proveedor."
                                                                                   Foreground="#6b7280"
                                                                                   FontSize="12"
                                                                                   TextWrapping="Wrap"
                                                                                   Margin="0,4,0,0" />
                                                                    </StackPanel>
                                                                </Grid>

                                                                <CheckBox x:Name="DeskIsComboCheck"
                                                                          Content="Producto tipo KIT o COMBO"
                                                                          Margin="0,0,0,8"
                                                                          Checked="DeskIsComboCheck_Changed"
                                                                          Unchecked="DeskIsComboCheck_Changed" />

                                                                <StackPanel x:Name="DeskComboPanel" Visibility="Collapsed">
                                                                    <TextBlock Text="Códigos de productos incluidos en el KIT/COMBO" FontWeight="SemiBold" />
                                                                    <TextBox x:Name="DeskComboCodesTextBox" Style="{StaticResource InputText}" Height="66" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />

                                                                    <Grid Margin="0,8,0,0">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <StackPanel Margin="0,0,8,0">
                                                                            <TextBlock Text="Seleccionar por categoría" FontWeight="SemiBold" />
                                                                            <ComboBox x:Name="DeskComboCategoryFilterComboBox" DisplayMemberPath="Name" SelectedValuePath="Id" Height="38" SelectionChanged="DeskComboCategoryFilterComboBox_SelectionChanged" />
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Column="1">
                                                                            <TextBlock Text="Seleccionar productos" FontWeight="SemiBold" />
                                                                            <ListBox x:Name="DeskComboProductsListBox" Height="90" SelectionMode="Extended" />
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </StackPanel>

                                                                <WrapPanel Margin="0,10,0,0">
                                                                    <Button Content="💾 Guardar producto" Width="170" Style="{StaticResource PrimaryButton}" Click="SaveInventoryProductButton_Click" />
                                                                    <Button Content="✏️ Editar producto" Width="160" Margin="8,10,0,0" Click="UpdateInventoryProductButton_Click" />
                                                                    <Button Content="🗑 Eliminar producto" Width="170" Margin="8,10,0,0" Click="DeleteInventoryProductButton_Click" />
                                                                </WrapPanel>
                                                            </StackPanel>
                                                        </ScrollViewer>
                                                    </TabItem>

                                                    <TabItem Header="Modificación de productos">
                                                        <StackPanel Margin="8">
                                                            <TextBlock Text="Aquí el dueño puede modificar: nombre, código, categoría, precio, si es KIT/COMBO y si maneja existencias."
                                                                       Foreground="#334155"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,0,0,10" />
                                                            <Button Content="🔄 Recargar productos" Width="180" Margin="0,0,0,8" Click="ReloadInventoryProductsButton_Click" />
                                                            <DataGrid x:Name="DeskInventoryProductsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column" RowHeaderWidth="0" Height="170" SelectionChanged="DeskInventoryProductsDataGrid_SelectionChanged">
                                                                <DataGrid.Columns>
                                                                    <DataGridTextColumn Header="Código" Binding="{Binding Code}" Width="*" />
                                                                    <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="2*" />
                                                                    <DataGridTextColumn Header="Categoría" Binding="{Binding CategoryName}" Width="*" />
                                                                    <DataGridTextColumn Header="Precio" Binding="{Binding PriceLabel}" Width="*" />
                                                                    <DataGridTextColumn Header="Tipo" Binding="{Binding TypeLabel}" Width="*" />
                                                                </DataGrid.Columns>
                                                            </DataGrid>
                                                        </StackPanel>
                                                    </TabItem>
                                                </TabControl>

                                                <TextBox x:Name="PosInventoryTextBox"
                                                         Visibility="Collapsed"
                                                         Text="Nuevo producto, edición, eliminación, ajustes de inventario, KIT/COMBO, categorías, promociones, importación Excel, catálogo, bajo inventario y kardex.&#x0a;Reglas clave: productos sin inventario fijo (ilimitados), mínimos para alertas, combos descuentan componentes." />
                                            </Grid>
                                        </TabItem>
                                        <TabItem Header="⚙️ Configuración">
                                            <TextBox x:Name="PosSystemConfigTextBox" Margin="0,8,0,0" Height="230" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                                     Text="Parámetros base, permisos por cajero, dispositivos, impresora, lector código barras, cajón, pagos, impuestos, corte, moneda, logo, básculas, compras/proveedores, nube, notificaciones, respaldos, actualizaciones y facturación electrónica." />
                                        </TabItem>
                                        <TabItem Header="🚚 Proveedores / Turnos / Alertas">
                                            <TextBox x:Name="PosOpsTextBox" Margin="0,8,0,0" Height="210" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                                     Text="Proveedores: recepción/pagos con lote-vencimiento y check de cambios en inventario.&#x0a;Turnos: biometría entrada/salida y consulta histórica por empleado.&#x0a;Alertas: SMS/correo por mínimos de inventario con frecuencia diaria/semanal/mensual." />
                                        </TabItem>
                                        <TabItem Header="✅ Checklist visual">
                                            <TextBox x:Name="PosChecklistTextBox" Margin="0,8,0,0" Height="170" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                                     Text="- Tabs principales creados&#x0a;- Formularios por módulo&#x0a;- Reglas de negocio documentadas&#x0a;- Persistencia app_web&#x0a;- Listo para siguientes iteraciones (gráficos, CRUD reales, biometría, SMS)." />
                                        </TabItem>
                                    </TabControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border x:Name="ProductCategoriesPanel" Visibility="Collapsed" Background="White" CornerRadius="12" Padding="14" BorderBrush="#e2e8f3" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel Margin="0,0,0,12">
                                <StackPanel DockPanel.Dock="Left">
