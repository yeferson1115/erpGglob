<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="Gglob.MainWindow"
        Title="Gglob ERP"
        Height="500"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#f8f9fa">

    <Window.Resources>

        <!-- Estilo Botón Primary -->
        <Style x:Key="PrimaryButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#0d6efd"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0b5ed7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo Botón Success -->
        <Style x:Key="SuccessButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#198754"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#157347"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <StackPanel VerticalAlignment="Top"
                    HorizontalAlignment="Center"
                    Width="600" Margin="0,180,0,0">

            <TextBlock Text="Sistema ERP - Gglob"
                       FontSize="32"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,40"
                       Foreground="#212529"/>

            <!-- Botones en horizontal -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Button Content="Dueño del Local"
                        Width="250"
                        Style="{StaticResource PrimaryButton}"
                        Click="btnDueno_Click"/>

                <Button Content="Cajero"
                        Width="250"
                        Style="{StaticResource SuccessButton}"
                        Click="btnCajero_Click"/>

            </StackPanel>

            <!-- Registro -->
            <TextBlock HorizontalAlignment="Center"
                       Margin="0,40,0,0"
                       FontSize="14"><Run Text="¿No tienes cuenta? "/><Hyperlink Click="Hyperlink_Click"
                           Foreground="#0d6efd"><Run Text="Regístrate aquí"/></Hyperlink></TextBlock>

        </StackPanel>
        <Image HorizontalAlignment="Left" Height="126" Margin="287,33,0,0" VerticalAlignment="Top" Width="246"/>

    </Grid>
</Window>