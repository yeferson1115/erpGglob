                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Text="Apellido" FontWeight="SemiBold" />
                                            <TextBox x:Name="CashierLastNameTextBox" Style="{StaticResource InputText}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Correo" FontWeight="SemiBold" />
                                            <TextBox x:Name="CashierEmailTextBox" Style="{StaticResource InputText}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Text="Teléfono" FontWeight="SemiBold" />
                                            <TextBox x:Name="CashierPhoneTextBox" Style="{StaticResource InputText}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock x:Name="CashierPasswordLabel" Text="Contraseña" FontWeight="SemiBold" />
                                            <PasswordBox x:Name="CashierPasswordBox" Style="{StaticResource InputPassword}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Bottom">
                                            <WrapPanel HorizontalAlignment="Right" Margin="0,12,0,0">
                                                <Button x:Name="ClearCashierFormButton" Content="🧹 Limpiar" Width="120" Height="36" Margin="0,0,8,0" Click="ClearCashierFormButton_Click" />
                                                <Button x:Name="SaveCashierButton" Content="👤 Crear cajero" Width="150" Height="36" Style="{StaticResource PrimaryButton}" Click="SaveCashierButton_Click" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <DataGrid x:Name="CashiersManagementDataGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column" RowHeaderWidth="0" MinHeight="240">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Nombre" Binding="{Binding FullName}" Width="2*" />
                                        <DataGridTextColumn Header="Correo" Binding="{Binding Email}" Width="2*" />
                                        <DataGridTextColumn Header="Teléfono" Binding="{Binding Phone}" Width="*" />
                                        <DataGridTemplateColumn Header="Acciones" Width="2*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="✏️ Editar" Tag="{Binding}" Margin="0,0,8,0" MinWidth="90" Height="34" Padding="12,6" Background="#e0ecff" BorderBrush="#bdd3ff" Click="EditCashierRowButton_Click" />
                                                        <Button Content="🗑 Eliminar" Tag="{Binding}" MinWidth="90" Height="34" Padding="12,6" Background="#ffe2e2" BorderBrush="#ffc6c6" Click="DeleteCashierRowButton_Click" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border x:Name="LoadingOverlay" Visibility="Collapsed" Background="#7F111827" CornerRadius="12">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="240">
                            <TextBlock Text="Procesando..." Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <ProgressBar IsIndeterminate="True" Height="16" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
