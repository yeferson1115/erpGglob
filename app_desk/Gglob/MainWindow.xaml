<Window
    x:Class="Gglob.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Gglob ERP Desk"
    Width="1180"
    Height="760"
    Background="#f4f6fb"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Resources>
        <SolidColorBrush x:Key="BrandBrush" Color="#2563eb" />
        <SolidColorBrush x:Key="BrandBrushHover" Color="#1d4ed8" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#ffffff" />
        <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#f8fafc" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#dbe3f0" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1f2937" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BrandBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome" Background="{TemplateBinding Background}" CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.2" Color="#1e3a8a" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource BrandBrushHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#f3f6fc" />
            <Setter Property="Foreground" Value="#1f2937" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SecondaryButtonChrome" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SecondaryButtonChrome" Property="Background" Value="#e8eefb" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="PrimaryButtonSpacious" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Padding" Value="18,12" />
        </Style>

        <Style x:Key="InputText" TargetType="TextBox">
            <Setter Property="Margin" Value="0,6,0,12" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="InputPassword" TargetType="PasswordBox">
            <Setter Property="Margin" Value="0,6,0,12" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,6,0,12" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="0,6,0,12" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="RowBackground" Value="White" />
            <Setter Property="AlternatingRowBackground" Value="#f8fafc" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#eef2ff" />
                        <Setter Property="Foreground" Value="#334155" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Padding" Value="8,6" />
                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,6" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="#e2e8f0" />
        </Style>

        <Style TargetType="Thumb">
            <Setter Property="Background" Value="#94a3b8" />
            <Setter Property="BorderBrush" Value="#94a3b8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#64748b" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid x:Name="LoginRoot">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="20" Background="#2b4f9e" CornerRadius="14" Margin="0,0,16,0">
                <StackPanel VerticalAlignment="Center">
                    <Image Source="/Images/logo.png" Width="220" Height="110" Stretch="Uniform" HorizontalAlignment="Left" />
                    <TextBlock Margin="0,18,0,0" TextWrapping="Wrap" Foreground="#e7f1ff" FontSize="15"
                               Text="Inicia sesión para entrar al Desk con menú lateral según servicios activos y permisos." />
                    <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#e7f1ff" FontSize="13"
                               Text="Validamos acceso activo, negocio asignado y rol (Dueño/Cajero)." />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Padding="28" Background="White" CornerRadius="14" BorderBrush="#dee2e6" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="🔐 Ingreso al sistema" FontSize="26" FontWeight="SemiBold" Foreground="#212529" />

                    <StackPanel Grid.Row="1" Margin="0,18,0,0">
                        <TextBlock Text="Correo" FontWeight="SemiBold" />
                        <TextBox x:Name="EmailTextBox" Style="{StaticResource InputText}" />

                        <TextBlock Text="Contraseña" FontWeight="SemiBold" />
                        <PasswordBox x:Name="PasswordBox" Style="{StaticResource InputPassword}" />

                        <Button x:Name="LoginButton" Style="{StaticResource PrimaryButton}" Click="LoginButton_Click" Content="Entrar al Desk" HorizontalAlignment="Stretch" MinHeight="44" />

                        <TextBlock x:Name="StatusTextBlock" Margin="0,12,0,4" Foreground="#495057" TextWrapping="Wrap" />

                        <TextBlock Margin="0,14,0,0" FontSize="14">
                            <Run Text="¿No tienes cuenta? " />
                            <Hyperlink Click="Hyperlink_Click" Foreground="#0d6efd">
                                <Run Text="Regístrate aquí" />
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="DashboardRoot" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,14,0" CornerRadius="14" Background="#264f9c" Padding="14">
                <DockPanel>
                    <Button DockPanel.Dock="Bottom" Style="{StaticResource PrimaryButton}" Content="🚪 Cerrar sesión" Padding="18,12" Click="LogoutButton_Click" />
                    <StackPanel>
                        <TextBlock Text="GglobERP Desk" Foreground="White" FontSize="22" FontWeight="Bold" />
                        <TextBlock x:Name="DashboardUserTextBlock" Margin="0,4,0,2" Foreground="#dce8ff" />
                        <TextBlock x:Name="DashboardBusinessTextBlock" Margin="0,0,0,12" Foreground="#dce8ff" TextWrapping="Wrap" />

                        <Border Background="#406fc8" CornerRadius="10" Padding="10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Rol en negocio" Foreground="#dce8ff" FontSize="12" />
                                <TextBlock x:Name="DashboardRoleTextBlock" Foreground="White" FontSize="15" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Servicios" Foreground="#dce8ff" FontSize="12" FontWeight="Bold" Margin="0,0,0,8" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="430">
                            <StackPanel x:Name="ServicesMenuPanel" />
                        </ScrollViewer>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Background="White" CornerRadius="12" Padding="14" BorderBrush="#e2e8f3" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="📊 Dashboard" FontSize="25" FontWeight="SemiBold" Foreground="#1f2937" />
                        <TextBlock Text="Vista principal por permisos y servicios activos." Foreground="#6b7280" Margin="0,3,0,10" />
                        <WrapPanel>
                            <Border Background="#e8f0ff" CornerRadius="8" Padding="8,5" Margin="0,0,8,8">
                                <TextBlock x:Name="PlanBadgeText" Foreground="#234ea0" FontWeight="SemiBold" />
                            </Border>
                            <Border Background="#ecfeff" CornerRadius="8" Padding="8,5" Margin="0,0,8,8">
                                <TextBlock x:Name="StatusBadgeText" Foreground="#0a7f8c" FontWeight="SemiBold" />
                            </Border>
                            <Border Background="#eafcf3" CornerRadius="8" Padding="8,5" Margin="0,0,8,8">
                                <TextBlock x:Name="ActiveServicesBadgeText" Foreground="#15803d" FontWeight="SemiBold" />
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border x:Name="AvailableModulesPanel" Grid.Row="1" Margin="0,12,0,0" Background="White" CornerRadius="12" Padding="14" BorderBrush="#e2e8f3" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="🧩 Módulos disponibles" FontSize="18" FontWeight="SemiBold" Foreground="#1f2937" Margin="0,0,0,10" />
                        <WrapPanel x:Name="ActiveServicesCardsPanel" />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Border x:Name="DefaultPanel" Background="White" CornerRadius="12" Padding="14" BorderBrush="#e2e8f3" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Resumen operativo" FontSize="18" FontWeight="SemiBold" Foreground="#1f2937" Margin="0,0,0,10" />
                            <TextBlock Text="Selecciona un servicio del menú lateral para abrir su módulo. Gglob Pay se mostrará al hacer clic en su opción." Foreground="#6b7280" TextWrapping="Wrap" Margin="0,0,0,12" />
                            <UniformGrid Columns="3" Rows="1">
                                <Border Margin="0,0,8,0" Padding="12" Background="#f8fbff" CornerRadius="8" BorderBrush="#d9e4ff" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Pagos del día" Foreground="#6b7280" />
                                        <TextBlock Text="$0" FontSize="20" FontWeight="Bold" Foreground="#234ea0" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,0,8,0" Padding="12" Background="#f8fbff" CornerRadius="8" BorderBrush="#d9e4ff" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Servicios activos" Foreground="#6b7280" />
                                        <TextBlock x:Name="SummaryServicesText" Text="0" FontSize="20" FontWeight="Bold" Foreground="#234ea0" />
                                    </StackPanel>
                                </Border>
                                <Border Padding="12" Background="#f8fbff" CornerRadius="8" BorderBrush="#d9e4ff" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Estado actual" Foreground="#6b7280" />
                                        <TextBlock Text="Listo" FontSize="20" FontWeight="Bold" Foreground="#15803d" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border x:Name="GglobPayPanel" Visibility="Collapsed" Background="White" CornerRadius="12" Padding="14" BorderBrush="#e2e8f3" BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <TabControl x:Name="GglobPayTabControl">
                        <TabItem x:Name="WompiConfigTab" Header="💳 Wompi">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Configuración Wompi (Solo Dueño)" FontWeight="SemiBold" Foreground="#1f2937" />
                                    <TextBlock Text="Llave pública" FontWeight="SemiBold" Margin="0,8,0,0" />
                                    <TextBox x:Name="WompiPublicKeyTextBox" Style="{StaticResource InputText}" />
                                    <TextBlock Text="Llave privada" FontWeight="SemiBold" />
                                    <TextBox x:Name="WompiPrivateKeyTextBox" Style="{StaticResource InputText}" />
                                    <TextBlock Text="Events secret" FontWeight="SemiBold" />
                                    <TextBox x:Name="WompiEventsSecretTextBox" Style="{StaticResource InputText}" />
                                    <Button x:Name="SaveWompiSettingsButton" Content="Guardar llaves Wompi" Width="220" Style="{StaticResource PrimaryButtonSpacious}" Click="SaveWompiSettingsButton_Click" />
                                </StackPanel>
                                <Border Grid.Column="1" Background="#f8fbff" CornerRadius="10" BorderThickness="1" BorderBrush="#d9e4ff" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="Flujo Wompi" FontWeight="SemiBold" FontSize="16" Foreground="#1f2937" />
                                        <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" Text="C# POS -> crear pago -> Laravel crea link Wompi y QR -> usuario escanea QR -> Wompi -> webhook Laravel -> pago confirmado." Foreground="#4b5563" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem x:Name="BancolombiaConfigTab" Header="🏦 Bancolombia">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.4*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Banco destino (solo Bancolombia)" FontWeight="SemiBold" />
                                    <ComboBox x:Name="DestinationBankComboBox" Margin="0,6,0,12" Height="34" />
                                    <TextBlock Text="Titular de cuenta" FontWeight="SemiBold" />
                                    <TextBox x:Name="DestinationHolderTextBox" Style="{StaticResource InputText}" />
                                    <TextBlock Text="Número de cuenta" FontWeight="SemiBold" />
                                    <TextBox x:Name="DestinationAccountNumberTextBox" Style="{StaticResource InputText}" />
                                    <TextBlock Text="Tipo de cuenta" FontWeight="SemiBold" />
                                    <ComboBox x:Name="DestinationAccountTypeComboBox" Margin="0,6,0,12" Height="34">
                                        <ComboBoxItem Content="Ahorros" IsSelected="True" />
                                        <ComboBoxItem Content="Corriente" />
                                    </ComboBox>
                                    <Button x:Name="SaveBancolombiaDestinationButton" Content="Guardar cuenta destino Bancolombia" Width="280" Style="{StaticResource PrimaryButtonSpacious}" Click="SaveDestinationAccountButton_Click" />

                                    <Separator Margin="0,10,0,10"/>
                                    <TextBlock Text="Configuración Bancolombia API (Solo Dueño)" FontWeight="SemiBold" Foreground="#1f2937" />
                                    <TextBlock Text="Base URL" FontWeight="SemiBold" Margin="0,8,0,0" />
                                    <TextBox x:Name="BancolombiaBaseUrlTextBox" Style="{StaticResource InputText}" />
                                    <TextBlock Text="Client ID" FontWeight="SemiBold" />
                                    <TextBox x:Name="BancolombiaClientIdTextBox" Style="{StaticResource InputText}" />
                                    <TextBlock Text="Client Secret" FontWeight="SemiBold" />
                                    <TextBox x:Name="BancolombiaClientSecretTextBox" Style="{StaticResource InputText}" />
                                    <Button x:Name="SaveBancolombiaSettingsButton" Content="Guardar parámetros Bancolombia" Width="260" Style="{StaticResource PrimaryButtonSpacious}" Click="SaveBancolombiaSettingsButton_Click" />
                                </StackPanel>
                                <Border Grid.Column="1" Background="#f8fbff" CornerRadius="10" BorderThickness="1" BorderBrush="#d9e4ff" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="Cuentas registradas" FontWeight="SemiBold" FontSize="16" Foreground="#1f2937" />
                                        <ListBox x:Name="DestinationAccountsListBox" Margin="0,12,0,0" Height="250" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </TabItem>

                        

                        <TabItem Header="🔳 Generar QR">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.3*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Cuenta para cobrar" FontWeight="SemiBold" />
                                    <ComboBox x:Name="QrAccountComboBox" Margin="0,6,0,12" Height="34" DisplayMemberPath="DisplayName" />
                                    <TextBlock Text="Precio" FontWeight="SemiBold" />
                                    <TextBox x:Name="QrAmountTextBox" Style="{StaticResource InputText}" />
                                    <TextBlock Text="Cajero / Caja" FontWeight="SemiBold" />
                                    <ComboBox x:Name="QrCashierComboBox" Margin="0,6,0,12" Height="34" />
                                    <Button Content="Generar QR Gglob Pay" Width="230" Style="{StaticResource PrimaryButtonSpacious}" Click="GenerateQrButton_Click" />
                                    <TextBlock x:Name="QrStatusTextBlock" Margin="0,12,0,0" Foreground="#065f46" TextWrapping="Wrap" />
                                </StackPanel>
                                <Border Grid.Column="1" Background="#f8fbff" CornerRadius="10" BorderThickness="1" BorderBrush="#d9e4ff" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="Código QR generado" FontWeight="SemiBold" FontSize="16" Foreground="#1f2937" />
                                        <Border Margin="0,12,0,0" BorderBrush="#d1d5db" BorderThickness="1" CornerRadius="8" Padding="8" Background="White" HorizontalAlignment="Center">
                                            <Image x:Name="QrImage" Width="190" Height="190" Stretch="Uniform" />
                                        </Border>
                                        <TextBlock Text="Checkout URL" Margin="0,10,0,0" FontWeight="SemiBold" Foreground="#1f2937" />
                                        <TextBox x:Name="QrCheckoutUrlTextBox" Margin="0,6,0,0" Height="58" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto" />
                                        <TextBox x:Name="QrPayloadTextBox" Margin="0,12,0,0" Height="170" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto" />
                                        <TextBlock Text="El payload QR contiene referencia, valor y cuenta receptora para verificación inmediata contra el banco receptor." Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#4b5563" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem Header="✅ Verificados">
                            <StackPanel Margin="10">
                                <WrapPanel Margin="0,0,0,10">
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Desde" FontWeight="SemiBold" />
                                        <DatePicker x:Name="VerifiedFromDatePicker" Width="150" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Hasta" FontWeight="SemiBold" />
                                        <DatePicker x:Name="VerifiedToDatePicker" Width="150" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Cajero" FontWeight="SemiBold" />
                                        <ComboBox x:Name="VerifiedCashierComboBox" Width="170" Height="32" />
                                    </StackPanel>
                                    <Button Content="Filtrar" Width="110" Height="32" Margin="0,18,10,0" Click="ApplyVerifiedFilterButton_Click" />
                                    <Button Content="Verificación manual Wompi" Width="210" Height="32" Margin="0,18,0,0" Click="ManualVerifyWompiButton_Click" />
                                </WrapPanel>
                                <DataGrid x:Name="VerifiedPaymentsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" Height="290">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Persona" Binding="{Binding SenderName}" Width="*" />
                                        <DataGridTextColumn Header="Cuenta" Binding="{Binding AccountNumber}" Width="*" />
                                        <DataGridTextColumn Header="Valor" Binding="{Binding AmountFormatted}" Width="120" />
                                        <DataGridTextColumn Header="Cajero" Binding="{Binding Cashier}" Width="120" />
                                        <DataGridTextColumn Header="Banco" Binding="{Binding Bank}" Width="140" />
                                        <DataGridTemplateColumn Header="Estado" Width="140">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusBrush}" FontWeight="SemiBold" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Hora" Binding="{Binding VerifiedAtFormatted}" Width="140" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="📈 Reportes">
                            <StackPanel Margin="10">
                                <WrapPanel Margin="0,0,0,10">
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Desde" FontWeight="SemiBold" />
                                        <DatePicker x:Name="ReportFromDatePicker" Width="150" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Hasta" FontWeight="SemiBold" />
                                        <DatePicker x:Name="ReportToDatePicker" Width="150" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Cajero" FontWeight="SemiBold" />
                                        <ComboBox x:Name="ReportCashierComboBox" Width="170" Height="32" />
                                    </StackPanel>
                                    <Button Content="Generar reporte" Width="140" Height="32" Margin="0,18,0,0" Click="GenerateReportButton_Click" />
                                </WrapPanel>

                                <Border Background="#f8fbff" CornerRadius="10" BorderThickness="1" BorderBrush="#d9e4ff" Padding="12" Margin="0,0,0,10">
                                    <WrapPanel>
                                        <StackPanel Width="210" Margin="0,0,10,0">
                                            <TextBlock Text="Total verificado" Foreground="#6b7280" />
                                            <TextBlock x:Name="ReportTotalAmountTextBlock" FontWeight="Bold" FontSize="22" Foreground="#1d4ed8" />
                                        </StackPanel>
                                        <StackPanel Width="210" Margin="0,0,10,0">
                                            <TextBlock Text="Cantidad de pagos" Foreground="#6b7280" />
                                            <TextBlock x:Name="ReportPaymentsCountTextBlock" FontWeight="Bold" FontSize="22" Foreground="#0f766e" />
                                        </StackPanel>
                                        <StackPanel Width="210">
                                            <TextBlock Text="Ticket promedio" Foreground="#6b7280" />
                                            <TextBlock x:Name="ReportAverageTextBlock" FontWeight="Bold" FontSize="22" Foreground="#7c3aed" />
                                        </StackPanel>
                                    </WrapPanel>
                                </Border>

                                <DataGrid x:Name="ReportPaymentsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" Height="190">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Referencia" Binding="{Binding ReferenceCode}" Width="*" />
                                        <DataGridTextColumn Header="Persona" Binding="{Binding SenderName}" Width="*" />
                                        <DataGridTextColumn Header="Valor" Binding="{Binding AmountFormatted}" Width="140" />
                                        <DataGridTextColumn Header="Cajero" Binding="{Binding Cashier}" Width="140" />
                                        <DataGridTextColumn Header="Fecha" Binding="{Binding VerifiedAtFullFormatted}" Width="170" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </TabItem>
                            </TabControl>
                        </ScrollViewer>
                    </Border>

                    <Border x:Name="CashRegistersPanel" Visibility="Collapsed" Background="White" CornerRadius="12" Padding="14" BorderBrush="#e2e8f3" BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="Gestión de cajas" FontWeight="SemiBold" FontSize="18" Foreground="#1f2937" />
                                    <TextBlock Text="Solo el dueño puede crear, editar, eliminar y asignar cajas a cajeros." Foreground="#6b7280" FontSize="12" />
                                </StackPanel>
                                <Button x:Name="CreateCashRegisterButton" DockPanel.Dock="Right" Content="+ Crear caja" Width="130" Height="34" Style="{StaticResource PrimaryButton}" Click="CreateCashRegisterButton_Click" />
                            </DockPanel>

                            <DataGrid x:Name="CashRegistersDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column" RowHeaderWidth="0">
                                <DataGrid.Resources>
                                    <Style x:Key="CashRegisterEditButtonStyle" TargetType="Button">
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="Background" Value="#1d4ed8" />
                                        <Setter Property="BorderBrush" Value="#1d4ed8" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Height" Value="34" />
                                        <Setter Property="MinWidth" Value="95" />
                                        <Setter Property="Padding" Value="12,6" />
                                        <Setter Property="Margin" Value="0,0,6,0" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="ActionButtonChrome" Background="{TemplateBinding Background}" CornerRadius="10">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ActionButtonChrome" Property="Background" Value="#1e40af" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                    <Style x:Key="CashRegisterAssignButtonStyle" TargetType="Button">
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="Background" Value="#0f766e" />
                                        <Setter Property="BorderBrush" Value="#0f766e" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Height" Value="34" />
                                        <Setter Property="MinWidth" Value="95" />
                                        <Setter Property="Padding" Value="12,6" />
                                        <Setter Property="Margin" Value="0,0,6,0" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="ActionButtonChrome" Background="{TemplateBinding Background}" CornerRadius="10">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ActionButtonChrome" Property="Background" Value="#0f5f59" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                    <Style x:Key="CashRegisterDeleteButtonStyle" TargetType="Button">
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="Background" Value="#b91c1c" />
                                        <Setter Property="BorderBrush" Value="#b91c1c" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Height" Value="34" />
                                        <Setter Property="MinWidth" Value="95" />
                                        <Setter Property="Padding" Value="12,6" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="ActionButtonChrome" Background="{TemplateBinding Background}" CornerRadius="10">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ActionButtonChrome" Property="Background" Value="#991b1b" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="2*" />
                                    <DataGridTextColumn Header="Código" Binding="{Binding Code}" Width="*" />
                                    <DataGridTextColumn Header="Estado" Binding="{Binding StatusLabel}" Width="*" />
                                    <DataGridTemplateColumn Header="Acciones" Width="2.6*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="✏️ Editar" Tag="{Binding}" Style="{StaticResource CashRegisterEditButtonStyle}" Click="EditCashRegisterRowButton_Click" />
                                                    <Button Content="👤 Asignar" Tag="{Binding}" Style="{StaticResource CashRegisterAssignButtonStyle}" Click="AssignCashRegisterRowButton_Click" />
                                                    <Button Content="🗑 Eliminar" Tag="{Binding}" Style="{StaticResource CashRegisterDeleteButtonStyle}" Margin="6,0,0,0" Click="DeleteCashRegisterRowButton_Click" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            </Grid>
                        </ScrollViewer>
                    </Border>



                    <Border x:Name="CashiersManagementPanel" Visibility="Collapsed" Background="White" CornerRadius="12" Padding="14" BorderBrush="#e2e8f3" BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="10">
                                <TextBlock Text="Usuarios cajeros" FontWeight="SemiBold" FontSize="18" Foreground="#1f2937" />
                                <TextBlock Text="Crea, edita o elimina los usuarios cajeros del negocio." Foreground="#6b7280" FontSize="12" Margin="0,0,0,12" />

                                <Border Background="#f8fbff" CornerRadius="10" BorderThickness="1" BorderBrush="#d9e4ff" Padding="12" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Nombre" FontWeight="SemiBold" />
                                            <TextBox x:Name="CashierNameTextBox" Style="{StaticResource InputText}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Text="Apellido" FontWeight="SemiBold" />
                                            <TextBox x:Name="CashierLastNameTextBox" Style="{StaticResource InputText}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Correo" FontWeight="SemiBold" />
                                            <TextBox x:Name="CashierEmailTextBox" Style="{StaticResource InputText}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Text="Teléfono" FontWeight="SemiBold" />
                                            <TextBox x:Name="CashierPhoneTextBox" Style="{StaticResource InputText}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock x:Name="CashierPasswordLabel" Text="Contraseña" FontWeight="SemiBold" />
                                            <PasswordBox x:Name="CashierPasswordBox" Style="{StaticResource InputPassword}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Bottom">
                                            <WrapPanel HorizontalAlignment="Right" Margin="0,12,0,0">
                                                <Button x:Name="ClearCashierFormButton" Content="🧹 Limpiar" Width="120" Height="36" Margin="0,0,8,0" Click="ClearCashierFormButton_Click" />
                                                <Button x:Name="SaveCashierButton" Content="👤 Crear cajero" Width="150" Height="36" Style="{StaticResource PrimaryButton}" Click="SaveCashierButton_Click" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <DataGrid x:Name="CashiersManagementDataGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column" RowHeaderWidth="0" MinHeight="240">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Nombre" Binding="{Binding FullName}" Width="2*" />
                                        <DataGridTextColumn Header="Correo" Binding="{Binding Email}" Width="2*" />
                                        <DataGridTextColumn Header="Teléfono" Binding="{Binding Phone}" Width="*" />
                                        <DataGridTemplateColumn Header="Acciones" Width="2*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="✏️ Editar" Tag="{Binding}" Margin="0,0,8,0" MinWidth="90" Height="34" Padding="12,6" Background="#e0ecff" BorderBrush="#bdd3ff" Click="EditCashierRowButton_Click" />
                                                        <Button Content="🗑 Eliminar" Tag="{Binding}" MinWidth="90" Height="34" Padding="12,6" Background="#ffe2e2" BorderBrush="#ffc6c6" Click="DeleteCashierRowButton_Click" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border x:Name="LoadingOverlay" Visibility="Collapsed" Background="#7F111827" CornerRadius="12">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="240">
                            <TextBlock Text="Procesando..." Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <ProgressBar IsIndeterminate="True" Height="16" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
