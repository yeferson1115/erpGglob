<Window
    x:Class="Gglob.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Gglob ERP Desk"
    Width="1180"
    Height="760"
    Background="#f4f6fb"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2f66d0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1f55bd" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputText" TargetType="TextBox">
            <Setter Property="Margin" Value="0,6,0,12" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="InputPassword" TargetType="PasswordBox">
            <Setter Property="Margin" Value="0,6,0,12" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid x:Name="LoginRoot">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="20" Background="#2b4f9e" CornerRadius="14" Margin="0,0,16,0">
                <StackPanel VerticalAlignment="Center">
                    <Image Source="/Images/logo.png" Width="220" Height="110" Stretch="Uniform" HorizontalAlignment="Left" />
                    <TextBlock Margin="0,18,0,0" TextWrapping="Wrap" Foreground="#e7f1ff" FontSize="15"
                               Text="Inicia sesión para entrar al Desk con menú lateral según servicios activos y permisos." />
                    <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#e7f1ff" FontSize="13"
                               Text="Validamos acceso activo, negocio asignado y rol (Dueño/Cajero)." />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Padding="28" Background="White" CornerRadius="14" BorderBrush="#dee2e6" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Ingreso al sistema" FontSize="26" FontWeight="SemiBold" Foreground="#212529" />

                    <StackPanel Grid.Row="1" Margin="0,18,0,0">
                        <TextBlock Text="Correo" FontWeight="SemiBold" />
                        <TextBox x:Name="EmailTextBox" Style="{StaticResource InputText}" />

                        <TextBlock Text="Contraseña" FontWeight="SemiBold" />
                        <PasswordBox x:Name="PasswordBox" Style="{StaticResource InputPassword}" />

                        <Button x:Name="LoginButton" Style="{StaticResource PrimaryButton}" Click="LoginButton_Click" Content="Iniciar sesión" Width="180" />

                        <TextBlock x:Name="StatusTextBlock" Margin="0,12,0,4" Foreground="#495057" TextWrapping="Wrap" />

                        <TextBlock Margin="0,14,0,0" FontSize="14">
                            <Run Text="¿No tienes cuenta? " />
                            <Hyperlink Click="Hyperlink_Click" Foreground="#0d6efd">
                                <Run Text="Regístrate aquí" />
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="DashboardRoot" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,14,0" CornerRadius="14" Background="#264f9c" Padding="14">
                <DockPanel>
                    <Button DockPanel.Dock="Bottom" Style="{StaticResource PrimaryButton}" Content="Cerrar sesión" Click="LogoutButton_Click" />
                    <StackPanel>
                        <TextBlock Text="GglobERP Desk" Foreground="White" FontSize="22" FontWeight="Bold" />
                        <TextBlock x:Name="DashboardUserTextBlock" Margin="0,4,0,2" Foreground="#dce8ff" />
                        <TextBlock x:Name="DashboardBusinessTextBlock" Margin="0,0,0,12" Foreground="#dce8ff" TextWrapping="Wrap" />

                        <Border Background="#406fc8" CornerRadius="10" Padding="10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Rol en negocio" Foreground="#dce8ff" FontSize="12" />
                                <TextBlock x:Name="DashboardRoleTextBlock" Foreground="White" FontSize="15" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Servicios" Foreground="#dce8ff" FontSize="12" FontWeight="Bold" Margin="0,0,0,8" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="430">
                            <StackPanel x:Name="ServicesMenuPanel" />
                        </ScrollViewer>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Background="White" CornerRadius="12" Padding="14" BorderBrush="#e2e8f3" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Dashboard" FontSize="25" FontWeight="SemiBold" Foreground="#1f2937" />
                        <TextBlock Text="Vista principal por permisos y servicios activos." Foreground="#6b7280" Margin="0,3,0,10" />
                        <WrapPanel>
                            <Border Background="#e8f0ff" CornerRadius="8" Padding="8,5" Margin="0,0,8,8">
                                <TextBlock x:Name="PlanBadgeText" Foreground="#234ea0" FontWeight="SemiBold" />
                            </Border>
                            <Border Background="#ecfeff" CornerRadius="8" Padding="8,5" Margin="0,0,8,8">
                                <TextBlock x:Name="StatusBadgeText" Foreground="#0a7f8c" FontWeight="SemiBold" />
                            </Border>
                            <Border Background="#eafcf3" CornerRadius="8" Padding="8,5" Margin="0,0,8,8">
                                <TextBlock x:Name="ActiveServicesBadgeText" Foreground="#15803d" FontWeight="SemiBold" />
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Margin="0,12,0,0" Background="White" CornerRadius="12" Padding="14" BorderBrush="#e2e8f3" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Módulos disponibles" FontSize="18" FontWeight="SemiBold" Foreground="#1f2937" Margin="0,0,0,10" />
                        <WrapPanel x:Name="ActiveServicesCardsPanel" />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Border x:Name="DefaultPanel" Background="White" CornerRadius="12" Padding="14" BorderBrush="#e2e8f3" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Resumen operativo" FontSize="18" FontWeight="SemiBold" Foreground="#1f2937" Margin="0,0,0,10" />
                            <TextBlock Text="Selecciona un servicio del menú lateral para abrir su módulo. Gglob Pay se mostrará al hacer clic en su opción." Foreground="#6b7280" TextWrapping="Wrap" Margin="0,0,0,12" />
                            <UniformGrid Columns="3" Rows="1">
                                <Border Margin="0,0,8,0" Padding="12" Background="#f8fbff" CornerRadius="8" BorderBrush="#d9e4ff" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Pagos del día" Foreground="#6b7280" />
                                        <TextBlock Text="$0" FontSize="20" FontWeight="Bold" Foreground="#234ea0" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,0,8,0" Padding="12" Background="#f8fbff" CornerRadius="8" BorderBrush="#d9e4ff" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Servicios activos" Foreground="#6b7280" />
                                        <TextBlock x:Name="SummaryServicesText" Text="0" FontSize="20" FontWeight="Bold" Foreground="#234ea0" />
                                    </StackPanel>
                                </Border>
                                <Border Padding="12" Background="#f8fbff" CornerRadius="8" BorderBrush="#d9e4ff" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Estado actual" Foreground="#6b7280" />
                                        <TextBlock Text="Listo" FontSize="20" FontWeight="Bold" Foreground="#15803d" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border x:Name="GglobPayPanel" Visibility="Collapsed" Background="White" CornerRadius="12" Padding="14" BorderBrush="#e2e8f3" BorderThickness="1">
                        <TabControl x:Name="GglobPayTabControl">
                        <TabItem Header="Wompi">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Configuración Wompi (Solo Dueño)" FontWeight="SemiBold" Foreground="#1f2937" />
                                    <TextBlock Text="Llave pública" FontWeight="SemiBold" Margin="0,8,0,0" />
                                    <TextBox x:Name="WompiPublicKeyTextBox" Style="{StaticResource InputText}" />
                                    <TextBlock Text="Llave privada" FontWeight="SemiBold" />
                                    <TextBox x:Name="WompiPrivateKeyTextBox" Style="{StaticResource InputText}" />
                                    <TextBlock Text="Events secret" FontWeight="SemiBold" />
                                    <TextBox x:Name="WompiEventsSecretTextBox" Style="{StaticResource InputText}" />
                                    <Button x:Name="SaveWompiSettingsButton" Content="Guardar llaves Wompi" Width="220" Style="{StaticResource PrimaryButton}" Click="SaveWompiSettingsButton_Click" />
                                </StackPanel>
                                <Border Grid.Column="1" Background="#f8fbff" CornerRadius="10" BorderThickness="1" BorderBrush="#d9e4ff" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="Flujo Wompi" FontWeight="SemiBold" FontSize="16" Foreground="#1f2937" />
                                        <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" Text="C# POS -> crear pago -> Laravel crea link Wompi y QR -> usuario escanea QR -> Wompi -> webhook Laravel -> pago confirmado." Foreground="#4b5563" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Bancolombia">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.4*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Banco destino (solo Bancolombia)" FontWeight="SemiBold" />
                                    <ComboBox x:Name="DestinationBankComboBox" Margin="0,6,0,12" Height="34" />
                                    <TextBlock Text="Titular de cuenta" FontWeight="SemiBold" />
                                    <TextBox x:Name="DestinationHolderTextBox" Style="{StaticResource InputText}" />
                                    <TextBlock Text="Número de cuenta" FontWeight="SemiBold" />
                                    <TextBox x:Name="DestinationAccountNumberTextBox" Style="{StaticResource InputText}" />
                                    <TextBlock Text="Tipo de cuenta" FontWeight="SemiBold" />
                                    <ComboBox x:Name="DestinationAccountTypeComboBox" Margin="0,6,0,12" Height="34">
                                        <ComboBoxItem Content="Ahorros" IsSelected="True" />
                                        <ComboBoxItem Content="Corriente" />
                                    </ComboBox>
                                    <Button x:Name="SaveBancolombiaDestinationButton" Content="Guardar cuenta destino Bancolombia" Width="280" Style="{StaticResource PrimaryButton}" Click="SaveDestinationAccountButton_Click" />

                                    <Separator Margin="0,10,0,10"/>
                                    <TextBlock Text="Configuración Bancolombia API (Solo Administrador)" FontWeight="SemiBold" Foreground="#1f2937" />
                                    <TextBlock Text="Base URL" FontWeight="SemiBold" Margin="0,8,0,0" />
                                    <TextBox x:Name="BancolombiaBaseUrlTextBox" Style="{StaticResource InputText}" />
                                    <TextBlock Text="Client ID" FontWeight="SemiBold" />
                                    <TextBox x:Name="BancolombiaClientIdTextBox" Style="{StaticResource InputText}" />
                                    <TextBlock Text="Client Secret" FontWeight="SemiBold" />
                                    <TextBox x:Name="BancolombiaClientSecretTextBox" Style="{StaticResource InputText}" />
                                    <Button x:Name="SaveBancolombiaSettingsButton" Content="Guardar parámetros Bancolombia" Width="260" Style="{StaticResource PrimaryButton}" Click="SaveBancolombiaSettingsButton_Click" />
                                </StackPanel>
                                <Border Grid.Column="1" Background="#f8fbff" CornerRadius="10" BorderThickness="1" BorderBrush="#d9e4ff" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="Cuentas registradas" FontWeight="SemiBold" FontSize="16" Foreground="#1f2937" />
                                        <ListBox x:Name="DestinationAccountsListBox" Margin="0,12,0,0" Height="250" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Cajas">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Gestión de cajas (admin)" FontWeight="SemiBold" />
                                    <TextBlock Text="Nombre" FontWeight="SemiBold" Margin="0,8,0,0" />
                                    <TextBox x:Name="CashRegisterNameTextBox" Style="{StaticResource InputText}" />
                                    <TextBlock Text="Código" FontWeight="SemiBold" />
                                    <TextBox x:Name="CashRegisterCodeTextBox" Style="{StaticResource InputText}" />
                                    <TextBlock Text="Estado" FontWeight="SemiBold" />
                                    <ComboBox x:Name="CashRegisterStatusComboBox" Margin="0,6,0,12" Height="34">
                                        <ComboBoxItem Content="active" IsSelected="True" />
                                        <ComboBoxItem Content="inactive" />
                                    </ComboBox>
                                    <Button x:Name="SaveCashRegisterButton" Content="Guardar caja" Width="180" Style="{StaticResource PrimaryButton}" Click="SaveCashRegisterButton_Click" />
                                    <Button x:Name="AssignCashRegisterButton" Content="Asignarme caja seleccionada" Width="220" Style="{StaticResource PrimaryButton}" Click="AssignCashRegisterButton_Click" />
                                </StackPanel>
                                <Border Grid.Column="1" Background="#f8fbff" CornerRadius="10" BorderThickness="1" BorderBrush="#d9e4ff" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="Cajas asignadas al usuario" FontWeight="SemiBold" FontSize="16" Foreground="#1f2937" />
                                        <ListBox x:Name="CashRegistersListBox" Margin="0,12,0,0" Height="220" DisplayMemberPath="Name" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Generar QR">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.3*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Cuenta para cobrar" FontWeight="SemiBold" />
                                    <ComboBox x:Name="QrAccountComboBox" Margin="0,6,0,12" Height="34" DisplayMemberPath="DisplayName" />
                                    <TextBlock Text="Precio" FontWeight="SemiBold" />
                                    <TextBox x:Name="QrAmountTextBox" Style="{StaticResource InputText}" />
                                    <TextBlock Text="Cajero / Caja" FontWeight="SemiBold" />
                                    <ComboBox x:Name="QrCashierComboBox" Margin="0,6,0,12" Height="34" />
                                    <Button Content="Generar QR Gglob Pay" Width="230" Style="{StaticResource PrimaryButton}" Click="GenerateQrButton_Click" />
                                    <TextBlock x:Name="QrStatusTextBlock" Margin="0,12,0,0" Foreground="#065f46" TextWrapping="Wrap" />
                                </StackPanel>
                                <Border Grid.Column="1" Background="#f8fbff" CornerRadius="10" BorderThickness="1" BorderBrush="#d9e4ff" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="Código QR generado" FontWeight="SemiBold" FontSize="16" Foreground="#1f2937" />
                                        <TextBox x:Name="QrPayloadTextBox" Margin="0,12,0,0" Height="170" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto" />
                                        <TextBlock Text="El payload QR contiene referencia, valor y cuenta receptora para verificación inmediata contra el banco receptor." Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#4b5563" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Verificados">
                            <StackPanel Margin="10">
                                <WrapPanel Margin="0,0,0,10">
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Desde" FontWeight="SemiBold" />
                                        <DatePicker x:Name="VerifiedFromDatePicker" Width="150" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Hasta" FontWeight="SemiBold" />
                                        <DatePicker x:Name="VerifiedToDatePicker" Width="150" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Cajero" FontWeight="SemiBold" />
                                        <ComboBox x:Name="VerifiedCashierComboBox" Width="170" Height="32" />
                                    </StackPanel>
                                    <Button Content="Filtrar" Width="110" Height="32" Margin="0,18,0,0" Click="ApplyVerifiedFilterButton_Click" />
                                </WrapPanel>
                                <DataGrid x:Name="VerifiedPaymentsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" Height="290">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Persona" Binding="{Binding SenderName}" Width="*" />
                                        <DataGridTextColumn Header="Cuenta" Binding="{Binding AccountNumber}" Width="*" />
                                        <DataGridTextColumn Header="Valor" Binding="{Binding AmountFormatted}" Width="120" />
                                        <DataGridTextColumn Header="Cajero" Binding="{Binding Cashier}" Width="120" />
                                        <DataGridTextColumn Header="Banco" Binding="{Binding Bank}" Width="140" />
                                        <DataGridTextColumn Header="Hora" Binding="{Binding VerifiedAtFormatted}" Width="140" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Reportes">
                            <StackPanel Margin="10">
                                <WrapPanel Margin="0,0,0,10">
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Desde" FontWeight="SemiBold" />
                                        <DatePicker x:Name="ReportFromDatePicker" Width="150" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Hasta" FontWeight="SemiBold" />
                                        <DatePicker x:Name="ReportToDatePicker" Width="150" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Cajero" FontWeight="SemiBold" />
                                        <ComboBox x:Name="ReportCashierComboBox" Width="170" Height="32" />
                                    </StackPanel>
                                    <Button Content="Generar reporte" Width="140" Height="32" Margin="0,18,0,0" Click="GenerateReportButton_Click" />
                                </WrapPanel>

                                <Border Background="#f8fbff" CornerRadius="10" BorderThickness="1" BorderBrush="#d9e4ff" Padding="12" Margin="0,0,0,10">
                                    <WrapPanel>
                                        <StackPanel Width="210" Margin="0,0,10,0">
                                            <TextBlock Text="Total verificado" Foreground="#6b7280" />
                                            <TextBlock x:Name="ReportTotalAmountTextBlock" FontWeight="Bold" FontSize="22" Foreground="#1d4ed8" />
                                        </StackPanel>
                                        <StackPanel Width="210" Margin="0,0,10,0">
                                            <TextBlock Text="Cantidad de pagos" Foreground="#6b7280" />
                                            <TextBlock x:Name="ReportPaymentsCountTextBlock" FontWeight="Bold" FontSize="22" Foreground="#0f766e" />
                                        </StackPanel>
                                        <StackPanel Width="210">
                                            <TextBlock Text="Ticket promedio" Foreground="#6b7280" />
                                            <TextBlock x:Name="ReportAverageTextBlock" FontWeight="Bold" FontSize="22" Foreground="#7c3aed" />
                                        </StackPanel>
                                    </WrapPanel>
                                </Border>

                                <DataGrid x:Name="ReportPaymentsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" Height="190">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Referencia" Binding="{Binding ReferenceCode}" Width="*" />
                                        <DataGridTextColumn Header="Persona" Binding="{Binding SenderName}" Width="*" />
                                        <DataGridTextColumn Header="Valor" Binding="{Binding AmountFormatted}" Width="140" />
                                        <DataGridTextColumn Header="Cajero" Binding="{Binding Cashier}" Width="140" />
                                        <DataGridTextColumn Header="Fecha" Binding="{Binding VerifiedAtFullFormatted}" Width="170" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </TabItem>
                        </TabControl>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
